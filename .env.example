SUPABASE_URL=
SUPABASE_SERVICE_KEY=
ANTHROPIC_API_KEY=
NICHE_TOOL_EXPORT_DIR=./input
# Postgres connection string — used by db/apply_schema.py + smoke_test schema check (psycopg).
# Supabase dashboard -> Project Settings -> Database -> Connection string (URI). Beyond SPEC-P00;
# see BOOTSTRAP.md "Deviations".
SUPABASE_DB_URL=
# P08 Interior Engine only: directory holding WeasyPrint's native GTK/Pango DLLs.
# Windows: install MSYS2 + `pacman -S mingw-w64-x86_64-pango`, then point here (its bin dir).
# Linux/WSL/macOS: leave blank — the libs are found on the system path.
WEASYPRINT_DLL_DIRECTORIES=C:\msys64\mingw64\bin
# P13 Etsy Publisher only: gate a REAL publish (createDraftListing -> activate). Leave blank to run
# the P13 acceptance test with its injected fake client (no creds, no fees). ETSY_API_KEY is the app
# keystring (x-api-key); ETSY_OAUTH_TOKEN is an OAuth2 access token with `listings_r listings_w`
# scope; ETSY_REFRESH_TOKEN renews it; ETSY_SHOP_ID is the target shop's numeric id.
ETSY_API_KEY=
ETSY_OAUTH_TOKEN=
ETSY_REFRESH_TOKEN=
ETSY_SHOP_ID=
